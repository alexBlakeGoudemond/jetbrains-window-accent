<idea-plugin require-restart="false" version="2"
             url="https://github.com/alexBlakeGoudemond/jetbrains-window-accent">

    <id>WindowAccent</id>
    <name>Window Accent</name>

    <vendor email="alexgoudemond@gmail.com">Alex Blake-Goudemond</vendor>

    <description><![CDATA[
        <h2>Window Accent</h2>
        Window Accent helps you distinguish between multiple JetBrains IDE windows with
        visual cues.

        <h3>The Challenge 🤔</h3>
        When you have multiple IDE windows open, it can be difficult to quickly identify
        which one is which, especially if they are all running the same project or have
        similar titles.

        <h3>The Solution ✨</h3>
        Window Accent allows you to apply different accents to each IDE window,
        making it easier to visually differentiate them at a glance.

        <h3>Configuration ⚙️</h3>
        Some configuration is available through the tool window as well as the settings.
        Please refer to screenshots etc. for insights into the features and configuration options.

        <h3>Related Plugins 📚</h3>
        Although similar to the following plugins, Window Accent is a separate implementation,
        created independently:
        <p>
        <ul>
            <li><a href="https://plugins.jetbrains.com/plugin/19463-project-color">Project Color</a></li>
            <li><a href="https://plugins.jetbrains.com/plugin/20920-colorized-project">Colorized Project</a></li>
        </ul>
    ]]></description>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <applicationListeners>
        <listener class="com.window_accent.PluginLifecycleListener"
                  topic="com.intellij.ide.plugins.DynamicPluginListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <!--
            Registering as an application service ensures IntelliJ calls dispose() on this
            service during plugin unloading, BEFORE the classloader GC check. This is the
            definitive cleanup hook that prevents "class loader cannot be unloaded" errors
            - and should allow for updating plugin without needing a restart.
        -->
        <applicationService serviceImplementation="com.window_accent.WindowAccentApplicationService"/>

        <toolWindow id="WindowAccent"
                    factoryClass="com.window_accent.configuration.tool_window.WindowAccentToolWindowFactory"
                    icon="/META-INF/simple-plugin-icon.svg"
                    anchor="left"
                    doNotActivateOnStart="true"/>
        <postStartupActivity implementation="com.window_accent.PluginStartupActivity"/>

        <projectConfigurable
                id="com.window_accent.windowAccentSettings"
                instance="com.window_accent.configuration.settings.WindowAccentSettings"
                parentId="appearance"
                displayName="Window Accent"/>
    </extensions>

    <!--
        Only recommended plugin dependencies put here: `com.intellij.modules.platform`
        This plugin only uses core IntelliJ Platform APIs:
        - Project and startup management (com.intellij.openapi.project, com.intellij.openapi.startup)
        - Application services (com.intellij.openapi.application)
        - Window management (com.intellij.openapi.wm)
        - UI components for tool windows and settings pages (com.intellij.openapi.ui)
        All of these are available in the base platform and don't require optional bundled plugins.
    -->
    <depends>com.intellij.modules.platform</depends>

</idea-plugin>