<idea-plugin require-restart="false" version="2"
             url="https://github.com/alexBlakeGoudemond/jetbrains-window-color-panel">

    <id>WindowColorPanel</id>
    <name>Window Color Panel</name>

    <vendor email="alexgoudemond@gmail.com">Alex Blake-Goudemond</vendor>

    <description>
        Window Color Panel helps you distinguish between multiple JetBrains IDE windows with visual cues.
        Some configuration is available through the tool window as well as the settings.
    </description>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="MyToolWindow"
                    factoryClass="com.window_color_panel.configuration.tool_window.WindowColorPanelToolWindowFactory"
                    icon="/META-INF/simple-plugin-icon.svg"/>
        <postStartupActivity implementation="com.window_color_panel.PluginStartupActivity"/>

        <projectConfigurable
                id="com.window_color_panel.windowColorSettings"
                instance="com.window_color_panel.configuration.settings.WindowColorPanelSettings"
                parentId="appearance"
                displayName="Window Color Panel"/>
    </extensions>

    <!--
        No plugin dependencies required - this plugin only uses core IntelliJ Platform APIs:
        - Project and startup management (com.intellij.openapi.project, com.intellij.openapi.startup)
        - Application services (com.intellij.openapi.application)
        - Window management (com.intellij.openapi.wm)
        - UI components for tool windows and settings pages (com.intellij.openapi.ui)
        All of these are available in the base platform and don't require optional bundled plugins.
    -->
    <!--    <depends></depends>-->

</idea-plugin>